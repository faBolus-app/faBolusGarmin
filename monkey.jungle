# Connect IQ build config for the PumpX2Garmin app (release; entry ControlX2App).
# Build:  monkeyc -f monkey.jungle -o bin/PumpX2Garmin.prg -y developer_key.der -d venu3s -w
# Unit tests use a separate config (test.jungle) with a minimal entry so the test harness
# isn't blocked by the app's background/timer lifecycle.
project.manifest = manifest.xml
base.sourcePath = source
