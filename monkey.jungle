# Connect IQ build config for PumpX2Garmin (standalone direct-to-pump venu3s app).
# Build:  monkeyc -f monkey.jungle -o bin/PumpX2Garmin.prg -y developer_key.der -d venu3s -w
# Test:   monkeyc -f monkey.jungle -o bin/PumpX2Garmin-test.prg -y developer_key.der -d venu3s --unit-test -w
#         monkeydo bin/PumpX2Garmin-test.prg venu3s -t
project.manifest = manifest.xml
# Test sources are included in the sourcePath; their (:test) functions are only compiled into
# --unit-test builds and stripped from release builds.
base.sourcePath = source;tests
