<complications>
    <!-- A single public BG complication. Default mode ("numericColor") publishes a NUMERIC :value so
         Face It range-colors it via the <range> bands below, with a Latin trend arrow in the :unit
         slot (rendered as e.g. "124 ^" in the band color). The earlier "BG reads 0" bug was caused
         by sending a STRING :value into this numeric/ranged complication — publish a real Number and
         it works. The "stringTrend" mode instead publishes a plain "124 ^" string (no color) for
         faces that don't range-color. Trend arrows are Latin/ASCII only (Face It can't rely on
         Unicode glyphs). Ranges are the glucose color bands (mg/dL): low / in-range / high / urgent. -->
    <complication id="0" access="public"
                  longLabel="@Strings.ComplicationLong"
                  shortLabel="@Strings.ComplicationShort"
                  icon="@Drawables.BgComplicationIcon"
                  glancePreview="true">
        <faceIt defaultText="@Strings.ComplicationFaceIt" />
        <range>
            <value>0</value>
            <value>70</value>
            <value>180</value>
            <value>250</value>
            <value>400</value>
        </range>
    </complication>
</complications>
