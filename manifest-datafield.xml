<?xml version="1.0" encoding="UTF-8"?>
<!-- faBolus BG data field (Connect IQ, type=datafield) — a separate app from the remote in
     source/app/. Shows glucose as a field on any activity screen, on watches AND Edge cycling
     computers. Scaffold: wire live BG via the faBolus public complication (see
     datafield/FaBolusDataField.mc). Built with datafield.jungle. In development for experimental use. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="FaBolusDataFieldApp"
                    id="c3d4e5f6a7b8c9d0e1f2030405060708"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppName"
                    type="datafield"
                    minSdkVersion="5.0.0">
        <iq:products>
            <iq:product id="venu3s"/>
            <iq:product id="fr265s"/>
            <iq:product id="fenix7"/>
            <iq:product id="edge540"/>
            <iq:product id="edge1040"/>
        </iq:products>
        <iq:permissions/>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
