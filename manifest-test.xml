<?xml version="1.0" encoding="UTF-8"?>
<!-- Manifest for UNIT-TEST builds only (test.jungle). Uses a minimal entry (TestEntryApp) so the
     test harness isn't blocked by the real app's background/timer lifecycle. Not shipped. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="TestEntryApp"
                    id="7f3c1b2a9d6e4f5081a2b3c4d5e6f708"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppName"
                    type="watch-app"
                    minSdkVersion="5.0.0">
        <iq:products>
            <iq:product id="venu3s"/>
        </iq:products>
        <!-- Only what the engine + shared resources need: ComplicationPublisher for the
             complications resource, BluetoothLowEnergy for the engine's BLE client module. -->
        <iq:permissions>
            <iq:uses-permission id="ComplicationPublisher"/>
            <iq:uses-permission id="BluetoothLowEnergy"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
