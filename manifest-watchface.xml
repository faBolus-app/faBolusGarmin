<?xml version="1.0" encoding="UTF-8"?>
<!-- faBolus watch face (Connect IQ, type=watch-face) — a separate app from the remote in
     source/app/. Scaffold: shows time + a BG slot (wire live BG via the faBolus public
     complication; see watchface/FaBolusFaceView.mc). Built with watchface.jungle. Watches only
     (Edge cycling computers have no watch face). In development for experimental use. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="FaBolusFaceApp"
                    id="b2c3d4e5f6a7b8c9d0e1f20304050607"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppName"
                    type="watchface"
                    minSdkVersion="5.0.0">
        <iq:products>
            <iq:product id="venu3s"/>
            <iq:product id="fr265s"/>
            <iq:product id="fenix7"/>
        </iq:products>
        <iq:permissions>
            <iq:uses-permission id="ComplicationSubscriber"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
