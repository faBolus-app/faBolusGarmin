<?xml version="1.0" encoding="UTF-8"?>
<!-- faBolus Garmin watch app (Connect IQ): phone-relay remote to the iPhone host (the phone owns
     the pump connection via PumpX2Kit). App id/entry preserved so the iOS ConnectIQ bridge targets
     it. A paused direct-to-pump effort lives under direct-pump/ (see DIRECT_PUMP_STATUS.md) and is
     not part of this build. In development for experimental use. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="FaBolusApp"
                    id="a1b2c3d4e5f600112233445566778899"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppName"
                    type="watch-app"
                    minSdkVersion="5.0.0">
        <iq:products>
            <!-- Touchscreen watch (hardware-validated). -->
            <iq:product id="venu3s"/>
            <!-- Button-only watch. -->
            <iq:product id="fenix7"/>
            <!-- Cycling computers (no watch face → no complication; see monkey.jungle). -->
            <iq:product id="edge540"/>
            <iq:product id="edge1040"/>
        </iq:products>
        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="ComplicationPublisher"/>
            <iq:uses-permission id="Background"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
