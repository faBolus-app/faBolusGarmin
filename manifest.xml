<?xml version="1.0" encoding="UTF-8"?>
<!-- faBolus Garmin watch app — BETA store listing. This is the second/experimental copy; the
     OFFICIAL listing is manifest-official.xml (a distinct app id). This id is the one the iOS
     ConnectIQ bridge currently targets (GarminRemoteBridge.watchAppUUID). A paused direct-to-pump
     effort lives under direct-pump/ (see DIRECT_PUMP_STATUS.md) and is not part of this build. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="FaBolusApp"
                    id="a1b2c3d4e5f600112233445566778899"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppNameBeta"
                    type="watch-app"
                    minSdkVersion="3.3.0">
        <iq:products>
            <!-- Touchscreen watches. venu3s is hardware-validated; fr265s (Forerunner 265S, AMOLED
                 touch, CIQ 5.2) shares the same touch input model. -->
            <iq:product id="venu3s"/>
            <iq:product id="fr265s"/>
            <!-- Button-only watches. fr245 (Forerunner 245, MIP, CIQ 3.3) has no Complications
                 module → its complication publisher is compiled out (see monkey.jungle). -->
            <iq:product id="fenix7"/>
            <iq:product id="fr245"/>
            <!-- Cycling computers (no watch face → no complication; see monkey.jungle). -->
            <iq:product id="edge540"/>
            <iq:product id="edge1040"/>
        </iq:products>
        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="ComplicationPublisher"/>
            <iq:uses-permission id="Background"/>
            <!-- Raw accel+gyro streaming for the eating-detection relay (EatingSenseKit barrel). -->
            <iq:uses-permission id="Sensor"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
        <!-- Reusable wrist eating-sensing library; built from the faBolusNudge SDK. -->
        <iq:barrels>
            <iq:depends name="EatingSenseKit" version="1.0.0"/>
        </iq:barrels>
    </iq:application>
</iq:manifest>
