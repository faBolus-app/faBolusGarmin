<?xml version="1.0" encoding="UTF-8"?>
<!-- faBolus Garmin watch app — OFFICIAL store listing. Identical to the beta (manifest.xml, same
     source + resources) except a distinct app id + the official name. Built via official.jungle.
     NOTE: this id differs from the one the iOS ConnectIQ bridge targets
     (GarminRemoteBridge.watchAppUUID = a1b2c3d4…, the beta). For the iPhone app to pair with this
     OFFICIAL Garmin app, point the bridge at this id (or have it target both). -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application entry="FaBolusApp"
                    id="ded131ecb69d46493650153aef623be6"
                    launcherIcon="@Drawables.LauncherIcon"
                    name="@Strings.AppName"
                    type="watch-app"
                    minSdkVersion="5.0.0">
        <iq:products>
            <!-- Touchscreen watches. venu3s is hardware-validated; fr265s (Forerunner 265S, AMOLED
                 touch, CIQ 5.2) shares the same touch input model. -->
            <iq:product id="venu3s"/>
            <iq:product id="fr265s"/>
            <!-- Button-only watch. -->
            <iq:product id="fenix7"/>
            <!-- Cycling computers (no watch face → no complication; see monkey.jungle). -->
            <iq:product id="edge540"/>
            <iq:product id="edge1040"/>
        </iq:products>
        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="ComplicationPublisher"/>
            <iq:uses-permission id="Background"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
